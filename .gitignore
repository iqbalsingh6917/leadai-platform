# ============================================================
# LeadAI Platform — .gitignore
# ============================================================

# ── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.yarn-integrity
package-lock.json
yarn.lock

# Build outputs
dist/
build/
out/
.output/

# Next.js
.next/
.vercel/
next-env.d.ts

# Coverage
coverage/
.nyc_output/
*.lcov

# TypeScript
*.tsbuildinfo

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache/
.pytest_cache/
htmlcov/
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# Re-include app source lib directories
!apps/*/src/lib/

# ── Environment Files ─────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging
.env.production
.env.*.local
!.env.example

# ── IDE & Editors ─────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.iml
*.iws
*.ipr
*.swp
*.swo
*~
.editorconfig.local
.project
.classpath
.settings/

# ── Operating System ──────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Docker ────────────────────────────────────────────────────
docker-compose.override.yml

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
log/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Test artifacts ────────────────────────────────────────────
test-results/
playwright-report/
playwright/.cache/
cypress/videos/
cypress/screenshots/
.jest-cache/

# ── Build artifacts ───────────────────────────────────────────
*.min.js
*.min.css
*.map
*.gz
*.br
.turbo/
.parcel-cache/

# ── Terraform ─────────────────────────────────────────────────
*.tfstate
*.tfstate.*
*.tfplan
.terraform/
.terraform.lock.hcl
crash.log
crash.*.log

# ── Kubernetes ────────────────────────────────────────────────
kubeconfig
*.kubeconfig

# ── Security / Secrets ────────────────────────────────────────
*.pem
*.key
*.crt
*.cer
*.pfx
*.p12
*.jks
serviceAccountKey.json
google-credentials.json

# ── Misc ──────────────────────────────────────────────────────
.cache/
tmp/
temp/
.tmp/
*.tmp
*.bak
*.backup
*.orig
*.rej
*.patch
Thumbs.db:encryptable
