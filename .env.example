# LeadAI Platform — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3001
API_URL=http://localhost:3000
PORT=3000
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3001

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://leadai:leadai_dev@localhost:5432/leadai
DATABASE_SSL=false
DATABASE_POOL_SIZE=10

# ── MongoDB ───────────────────────────────────────────────────
MONGODB_URI=mongodb://leadai:leadai_dev@localhost:27017/leadai?authSource=admin
MONGODB_DB_NAME=leadai

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=leadai-api
KAFKA_GROUP_ID=leadai-consumers

# ── Elasticsearch ─────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ── Authentication ────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-min-32-char-secret-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
AUTH_PROVIDER=local
# For Keycloak:
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=leadai
KEYCLOAK_CLIENT_ID=leadai-api
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret

# ── AI / LLM APIs ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GOOGLE_AI_API_KEY=AIzaSy-your-google-ai-api-key-here
GOOGLE_AI_MODEL=gemini-1.5-pro

# Vector DB
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=leadai-vectors

# ── WhatsApp Business API ─────────────────────────────────────
WHATSAPP_API_TOKEN=your-whatsapp-business-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
WHATSAPP_WEBHOOK_SECRET=your-webhook-verification-token

# ── Email ─────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@leadai.in
SENDGRID_FROM_NAME=LeadAI Platform
# Alternative: Mailgun
MAILGUN_API_KEY=key-your-mailgun-api-key
MAILGUN_DOMAIN=mg.leadai.in

# ── Payment ───────────────────────────────────────────────────
# Razorpay (India)
RAZORPAY_KEY_ID=rzp_test_your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
# Stripe (Global)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ── AWS ───────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
S3_BUCKET=leadai-uploads-dev
S3_CDN_URL=https://cdn.leadai.in
